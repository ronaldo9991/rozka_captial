# Database Configuration
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Session Secret (generate a random string)
# SESSION_SECRET=your-session-secret-key-change-this-in-production

# Server Configuration
# PORT=5000
# NODE_ENV=development

# Stripe Payment Gateway (Sandbox/Test Mode)
# Get your keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Frontend Stripe Publishable Key (for Vite - must be prefixed with VITE_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Webhook Secret (get this from Stripe Dashboard after setting up webhook)
# For local development, use: stripe listen --forward-to localhost:5000/api/stripe/webhook
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Frontend URL (for Stripe redirects)
# FRONTEND_URL=http://localhost:3000  # Development
# FRONTEND_URL=https://yourdomain.com  # Production

# Optional: MT5 Integration
# MT5_ENABLED=false
# MT5_HOST=your-mt5-server.com
# MT5_PORT=443
# MT5_MANAGER_LOGIN=your_manager_login
# MT5_MANAGER_PASSWORD=your_password
