{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --external:vite --external:@vitejs/* --external:@replit/* --external:../vite.config.js --outdir=dist --bundle=true && node scripts/sync-static.mjs",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start:apprunner": "node server/start-simple.js",
    "start:full": "node server/start-apprunner.js",
    "start:debug": "node server/debug-start.js",
    "check": "tsc",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "db:push": "drizzle-kit push",
    "migrate:rds": "tsx scripts/migrate-to-rds.ts",
    "check:data": "tsx scripts/check-database-data.ts",
    "verify:db": "tsx scripts/verify-database-connection.ts",
    "clean": "rm -rf dist node_modules/.vite",
    "deploy:build": "npm ci && npm run build"
  },
